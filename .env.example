# n8n webhook base URL (no trailing slash)
VITE_N8N_BASE_URL=https://your-n8n-instance.example.com
# Proxy token for n8n admin-api webhook authentication
VITE_PROXY_TOKEN=your-proxy-token-here
# Supabase public storage URL
VITE_SUPABASE_PUBLIC_URL=https://your-project.supabase.co/storage/v1/object/public
